# LIFELINE environment configuration.
# Copy to .env and fill in. Never commit .env.

# bcrypt hash of the owner password. Generate with:  npm run hash -- 'your-password'
OWNER_PASSWORD_HASH=

# Secret used to sign the session JWT cookie. Use a long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Server port (the API + the built SPA are served from here in production).
PORT=3000

# Path to the SQLite database file (created on first boot).
DATABASE_PATH=./data/lifeline.db

# Set to "true" in production (HTTPS) so the session cookie is marked Secure.
COOKIE_SECURE=false

# Owner timezone — "today" boundaries are computed here, not in UTC.
OWNER_TZ=Asia/Kolkata
